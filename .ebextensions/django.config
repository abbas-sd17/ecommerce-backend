# AWS Elastic Beanstalk configuration
# Lecture 8 — EBS deployment config
# This file is read by EBS to install dependencies and start Gunicorn
#
# Set in EB console → Configuration → Software → Environment properties:
#   DJANGO_SETTINGS_MODULE, RAZORPAY_ID, RAZORPAY_SECRET,
#   RAZORPAY_CALLBACK_URL (public https URL), RAZORPAY_WEBHOOK_SECRET

option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: ecommerce_backend.wsgi:application

container_commands:
  01_migrate:
    command: "python manage.py migrate --noinput"
    leader_only: true
  02_collectstatic:
    command: "python manage.py collectstatic --noinput"
    leader_only: true

packages:
  yum:
    python3-devel: []
    mysql-devel: []
